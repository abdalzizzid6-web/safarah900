rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      // Check database role for admin
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['SUPER_ADMIN', 'ADMIN', 'super_admin', 'admin'])
      );
    }
    function isEditor() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['SUPER_ADMIN', 'ADMIN', 'EDITOR', 'admin', 'editor'])
      );
    }
    function isModerator() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['SUPER_ADMIN', 'ADMIN', 'EDITOR', 'MODERATOR', 'admin', 'editor', 'moderator'])
      );
    }
    function isAuthor() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['SUPER_ADMIN', 'ADMIN', 'EDITOR', 'AUTHOR', 'admin', 'editor', 'author'])
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Users can create their own profile
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Users can update their own profile, but NOT their role
      allow update: if isSignedIn() && request.auth.uid == userId && 
                       (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isSignedIn() && isAdmin();
    }

    match /settings/{settingId} {
      // Configuration, branding, and world cup settings are public (anyone can read to render the app)
      // data_sources setting includes API keys and is isEditor only
      allow read: if (settingId in ['branding', 'config', 'world_cup']) || (isSignedIn() && isEditor());
      allow write: if isSignedIn() && isEditor();
    }

    match /analytics_events/{eventId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn() && isEditor();
    }

    match /analytics_presence/{presenceId} {
      allow read: if isSignedIn() && isEditor();
      allow write: if isSignedIn();
    }

    match /analytics_daily/{dateStr} {
      allow read: if isSignedIn() && isEditor();
      allow write: if isSignedIn();
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isSignedIn() && isAuthor();
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && (isEditor() || resource.data.userId == request.auth.uid);
      }
    }

    match /news_categories/{categoryId} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /rss_sources/{sourceId} {
      allow read, write: if isSignedIn() && isEditor();
    }

    match /stadiums/{stadiumId} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /competitions/{compId} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /predictions/{predId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId']));
      allow delete: if isSignedIn() && isEditor();
    }

    match /prediction_aggregates/{matchId} {
      allow read: if true;
      allow create, update: if isSignedIn();
    }

    match /user_points/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /esports_registrations/{regId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isEditor());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && isEditor();
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isEditor());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && isEditor();
    }

    match /sports_events/{eventId} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /sports_registrations/{regId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isEditor());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && isEditor();
    }

    match /poll_responses/{responseId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isEditor();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /vip_subscriptions/{subId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow write: if isSignedIn() && isAdmin();
    }

    match /premium_service_requests/{reqId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow write: if isSignedIn() && isAdmin();
    }

    match /ad_campaigns/{campId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isEditor());
      allow delete: if isSignedIn() && isEditor();
    }

    match /cms_channels_servers/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /match_ai_content/{matchId} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /matchStreams/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /cms_leagues/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /cms_match_overrides/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /cms_teams/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /cms_team_overrides/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /sources/{sourceId} {
      allow read: if isSignedIn() && isEditor();
      allow write: if isSignedIn() && isEditor();
    }

    match /system_logs/{logId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn() && isEditor();
    }

    match /activity_logs/{logId} {
      allow read: if isSignedIn() && isEditor();
      allow create: if true;
      allow update, delete: if isSignedIn() && isEditor();
    }

    match /match_logs/{logId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && isEditor();
    }

    match /announcements/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /ads/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /fcm_tokens/{tokenId} {
      allow read: if isSignedIn() && isEditor();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isEditor();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource == null || resource.data.targetUids.hasAny([request.auth.uid]));
      allow create: if isSignedIn() && isEditor();
      allow update: if isSignedIn() && (
        resource.data.targetUids.hasAny([request.auth.uid]) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead'])
      );
      allow delete: if isSignedIn() && isEditor();
    }

    // Additional Missing Collections Rules to satisfy Dashboard and stats queries
    match /system_stats/{id} {
      allow read: if isSignedIn() && isAuthor();
      allow write: if isSignedIn() && isEditor();
    }

    match /social_accounts/{id} {
      allow read, write: if isEditor();
    }
    
    match /social_accounts_audit/{id} {
      allow read, write: if isEditor();
    }

    match /social_queue/{id} {
      allow read, write: if isEditor();
    }

    match /social_logs/{id} {
      allow read, write: if isEditor();
    }

    match /social_media_analytics/{id} {
      allow read, write: if isEditor();
    }

    match /stadium_bookings/{id} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isEditor());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && isEditor();
    }

    match /contact_messages/{id} {
      allow create: if true;
      allow read, update, delete: if isSignedIn() && isEditor();
    }

    match /world_cup_players/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /standings/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /media_assets/{id} {
      allow read, write: if isSignedIn() && isEditor();
    }

    match /media_folders/{id} {
      allow read, write: if isSignedIn() && isEditor();
    }

    match /media_collections/{id} {
      allow read, write: if isSignedIn() && isEditor();
    }

    match /indexing_logs/{id} {
      allow read, write: if isSignedIn() && isEditor();
    }

    match /news_tags/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /leagues/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /teams/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /players/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /channels/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /prizes/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /error_logs/{logId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && isEditor();
    }

    match /api_logs/{logId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && isEditor();
    }

    match /sync_logs/{logId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && isEditor();
    }

    match /notification_history/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isEditor());
      allow write: if isSignedIn() && isEditor();
    }

    match /page_views/{id} {
      allow read: if isSignedIn() && isEditor();
      allow write: if isSignedIn();
    }

    match /match_views/{id} {
      allow read: if isSignedIn() && isEditor();
      allow write: if isSignedIn();
    }

    match /team_views/{id} {
      allow read: if isSignedIn() && isEditor();
      allow write: if isSignedIn();
    }

    match /player_views/{id} {
      allow read: if isSignedIn() && isEditor();
      allow write: if isSignedIn();
    }

    match /stream_views/{id} {
      allow read: if isSignedIn() && isEditor();
      allow write: if isSignedIn();
    }

    match /user_activity/{id} {
      allow read: if isSignedIn() && isEditor();
      allow write: if isSignedIn();
    }

    match /deleted_matches/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /chat_messages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && 
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.text is string &&
                    request.resource.data.text.size() <= 1000;
      allow update, delete: if isSignedIn() && (
        isModerator() || 
        resource.data.userId == request.auth.uid
      );
    }

    match /chat_settings/{settingId} {
      allow read: if true;
      allow write: if isSignedIn() && isModerator();
    }

    match /api_providers/{providerId} {
      allow read, write: if isSignedIn() && isEditor();
    }

    match /api_logs_v2/{logId} {
      allow read: if isSignedIn() && isEditor();
      allow create: if isSignedIn() && isEditor();
      allow update, delete: if false;
    }

    match /match_versions/{versionId} {
      allow read, create: if isSignedIn() && isEditor();
      allow update, delete: if false;
    }

    match /match_audit_logs/{logId} {
      allow read, create: if isSignedIn() && isEditor();
      allow update, delete: if false;
    }

    match /match_locks/{matchId} {
      allow read, write: if isSignedIn() && isEditor();
    }

    match /match_follows/{followId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isEditor());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
                       (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'matchId']));
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isEditor());
    }

    // 14. RSS Imports & News Sources
    }

      allow read: if isSignedIn() && isEditor();
      allow update, delete: if false;
    }

    }

    match /rss_imports/{articleId} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    // 15. Experience Builder (Homepage V2) Collections
    match /homepage_blocks/{blockId} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /homepage_layouts/{layoutId} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

    match /homepage_templates/{templateId} {
      allow read: if true;
      allow write: if isSignedIn() && isEditor();
    }

  }
}
