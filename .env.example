# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
# VITE environment variables for football API
VITE_RAPID_API_KEY=
VITE_FOOTBALL_DATA_KEY=
VITE_FOOTBALL_DATA_BASE=https://api.football-data.org/v4
VITE_API_KEY=
VITE_API_BASE_URL=https://v3.football.api-sports.io
VITE_API_FOOTBALL_KEY=
VITE_API_FOOTBALL_BASE=https://v3.football.api-sports.io

# FIREBASE_SERVICE_ACCOUNT_KEY: Required for secure backend Firebase Admin SDK access.
# Also used for Google Indexing API. Ensure the service account email has "Owner" 
# permission in Google Search Console for your domain.
FIREBASE_SERVICE_ACCOUNT_KEY=

# ImageKit: For media storage and optimization
# Server-side
IMAGEKIT_PUBLIC=public_m48LSWaMNw1vDEpM7RKgqUFqYdE
IMAGEKIT_PRIVATE=PRIVATE_KEY_NEW
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/2n3gvscsl
# Client-side
VITE_IMAGEKIT_PUBLIC=public_m48LSWaMNw1vDEpM7RKgqUFqYdE
VITE_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/2n3gvscsl

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Firebase Cloud Messaging VAPID key
VITE_FCM_VAPID_KEY=

# ENCRYPTION_KEY: AES-256 key for sensitive data encryption (32 bytes hex string)
ENCRYPTION_KEY=

# GitHub synchronization credentials
GITHUB_TOKEN=
GITHUB_REPO_URL=
