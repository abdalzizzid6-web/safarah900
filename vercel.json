{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/seo?action=sitemap&type=index"
    },
    {
      "source": "/sitemap-main.xml",
      "destination": "/api/seo?action=sitemap&type=main"
    },
    {
      "source": "/sitemap-matches.xml",
      "destination": "/api/seo?action=sitemap&type=matches"
    },
    {
      "source": "/sitemap-news.xml",
      "destination": "/api/seo?action=sitemap&type=news"
    },
    {
      "source": "/sitemap-images.xml",
      "destination": "/api/seo?action=sitemap&type=images"
    },
    {
      "source": "/sitemap-leagues.xml",
      "destination": "/api/seo?action=sitemap&type=leagues"
    },
    {
      "source": "/sitemap-teams.xml",
      "destination": "/api/seo?action=sitemap&type=teams"
    },
    {
      "source": "/sitemap-players.xml",
      "destination": "/api/seo?action=sitemap&type=players"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/seo?action=robots"
    },
    {
      "source": "/api/imagekit/files/:fileId",
      "destination": "/api/imagekit?action=files&fileId=:fileId"
    },
    {
      "source": "/api/imagekit/files",
      "destination": "/api/imagekit?action=files"
    },
    {
      "source": "/api/imagekit/upload",
      "destination": "/api/imagekit?action=upload"
    },
    {
      "source": "/api/ai/match-analysis",
      "destination": "/api/ai?action=match-analysis"
    },
    {
      "source": "/api/ai/tactical-analysis",
      "destination": "/api/ai?action=tactical-analysis"
    },
    {
      "source": "/api/ai/match-content",
      "destination": "/api/ai?action=match-content"
    },
    {
      "source": "/api/matches/cron",
      "destination": "/api/matches?action=cron"
    },
    {
      "source": "/api/matches/events",
      "destination": "/api/matches?action=events"
    },
    {
      "source": "/api/matches/sync",
      "destination": "/api/matches?action=sync"
    },
    {
      "source": "/api/rss/providers",
      "destination": "/api/rss?action=providers"
    },
    {
      "source": "/api/rss/sync",
      "destination": "/api/rss?action=sync"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!api/|sitemap|robots\\.txt|manifest\\.json|ads\\.txt|.*\\.).*)",
      "destination": "/api/seo?action=render"
    }
  ],
  "headers": [
    {
      "source": "/sitemap(.*)\\.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    }
  ]
}
