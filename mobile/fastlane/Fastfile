# Fastfile defines our build pipeline lanes
default_platform(:ios)

platform :ios do
  desc "Push a new beta build to Apple TestFlight"
  lane :beta do
    # 1. Sync certificates and provisioning profiles
    match(type: "appstore", readonly: true)
    
    # 2. Increment build number
    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || "1"
    )
    
    # 3. Compile the iOS app bundle using Expo configuration
    gym(
      scheme: "koralive-mobile",
      export_method: "app-store"
    )
    
    # 4. Upload built IPA to TestFlight using Pilot
    pilot(
      skip_waiting_to_process: true,
      skip_submission: false
    )
  end

  desc "Promote beta to App Store Production"
  lane :release do
    deliver(
      force: true,
      skip_metadata: false,
      skip_screenshots: true
    )
  end
end

platform :android do
  desc "Submit AAB to Google Play Console Internal Track"
  lane :play_store_internal do
    # Supply downloads, edits, and uploads packages to Google Play Console
    supply(
      track: "internal",
      aab: "../android/app/build/outputs/bundle/release/app-release.aab"
    )
  end

  desc "Submit metadata updates to Google Play"
  lane :update_metadata do
    supply(
      skip_upload_apk: true,
      skip_upload_bundle: true
    )
  end
end
